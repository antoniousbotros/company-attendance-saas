{
  "project_name": "SyncTime SaaS Attendance",
  "stack": {
    "frontend": "Next.js 16 (App Router + Turbopack)",
    "backend": "Next.js API Routes (Serverless) + Telegram Bot (Telegraf)",
    "database": "Supabase (PostgreSQL + RLS + Realtime)",
    "hosting": "Vercel (Frontend/API) + Supabase (DB/Storage)"
  },
  "architecture": {
    "type": "Monolith (Full-stack Next.js)",
    "multi_tenant": true,
    "subdomain_logic": true,
    "subdomains": {
      "www": "Marketing/Landing Page",
      "app": "Main Dashboard (Owners)",
      "team": "Employee App (Web Portal)",
      "sadmin": "Administrative Control Plane (System Admins)"
    }
  },
  "critical_modules": [
    "src/middleware.ts",
    "src/app/api/telegram/webhook/route.ts",
    "src/app/api/billing/checkout/route.ts",
    "src/app/api/olisaas/fulfill/route.ts",
    "src/lib/supabase.ts",
    "src/lib/billing.ts"
  ],
  "sensitive_areas": [
    "auth (Owner/Employee)",
    "billing",
    "subdomain_rewriting",
    "database_schema",
    "telegram_bot_parsing",
    "owner_otp_verification"
  ]
}
